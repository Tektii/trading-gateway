{
  "permissions": {
    "allow": [
      "Bash(cargo build:*)",
      "Bash(cargo check:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo nextest:*)",
      "Bash(cargo deny:*)",
      "Bash(cargo tree:*)",
      "Bash(rustfmt:*)",
      "Bash(make:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(git ls-remote:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Bash(git add .:*)",
      "Bash(git add -A:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.rs)|Write(*.rs)",
            "command": "jq -r '.tool_input.file_path' | xargs rustfmt"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(jq -r '.tool_input.command') && echo \"$CMD\" | grep -qE '^cargo[[:space:]]+test' && ! echo \"$CMD\" | grep -q 'nextest' && { echo 'Use cargo nextest, not cargo test. See CLAUDE.md conventions.' >&2; exit 2; } || exit 0"
          }
        ]
      }
    ]
  }
}
