# =============================================================================
# Tektii Gateway — Environment Variables
# =============================================================================
# Copy to .env and fill in values:  cp .env.example .env

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# GATEWAY_HOST=127.0.0.1
# GATEWAY_PORT=8080
# RUST_LOG=info

# -----------------------------------------------------------------------------
# Provider (required — which broker to connect to)
# -----------------------------------------------------------------------------
# Valid values: alpaca, binance_spot, oanda, saxo
GATEWAY_PROVIDER=

# -----------------------------------------------------------------------------
# Trading Mode
# -----------------------------------------------------------------------------
# paper = paper/testnet trading (default), live = real funds
# GATEWAY_MODE=paper

# -----------------------------------------------------------------------------
# Swagger UI (serves interactive API docs at /swagger-ui)
# -----------------------------------------------------------------------------
# Disabled by default. When enabled with auth, Swagger UI requires authentication.
# ENABLE_SWAGGER=true

# -----------------------------------------------------------------------------
# Authentication (optional — when set, all /v1/* endpoints require a Bearer token)
# -----------------------------------------------------------------------------
# Minimum 32 characters. Clients must send Authorization: Bearer <key> or X-API-Key: <key>.
# When unset, the gateway runs without authentication.
# Generate with: openssl rand -hex 32
# GATEWAY_API_KEY=

# -----------------------------------------------------------------------------
# Subscriptions (JSON array of WebSocket subscriptions, optional)
# -----------------------------------------------------------------------------
# SUBSCRIPTIONS='[{"platform":"alpaca-paper","instrument":"AAPL","events":["quote"]}]'

# -----------------------------------------------------------------------------
# Alpaca
# -----------------------------------------------------------------------------
# ALPACA_API_KEY=
# ALPACA_API_SECRET=
# ALPACA_BASE_URL=https://paper-api.alpaca.markets
# ALPACA_DATA_URL=https://data.alpaca.markets
# ALPACA_STREAM_URL=wss://stream.data.alpaca.markets
# ALPACA_FEED=iex              # iex, sip, or crypto

# -----------------------------------------------------------------------------
# Binance
# -----------------------------------------------------------------------------
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# BINANCE_BASE_URL=https://api.binance.com
# BINANCE_STREAM_URL=wss://stream.binance.com:9443
# BINANCE_ACCOUNT_TYPE=spot    # spot

# -----------------------------------------------------------------------------
# Oanda
# -----------------------------------------------------------------------------
# OANDA_API_KEY=
# OANDA_ACCOUNT_ID=
# OANDA_BASE_URL=https://api-fxpractice.oanda.com
# OANDA_STREAM_URL=https://stream-fxpractice.oanda.com

# -----------------------------------------------------------------------------
# Saxo
# -----------------------------------------------------------------------------
# SAXO_APP_KEY=
# SAXO_APP_SECRET=
# SAXO_ACCOUNT_KEY=
# SAXO_ACCESS_TOKEN=
# SAXO_REFRESH_TOKEN=
# SAXO_BASE_URL=https://gateway.saxobank.com/sim/openapi
# SAXO_STREAM_URL=wss://streaming.saxobank.com/sim/openapi

# -----------------------------------------------------------------------------
# Advanced — Exit Management
# -----------------------------------------------------------------------------
# Time-to-live for pending SL/TP exit orders (hours)
# SL_TP_TTL_HOURS=24

# File path for persisting exit order state across restarts
# EXIT_STATE_FILE=./gateway-exit-state.json

# -----------------------------------------------------------------------------
# Advanced — WebSocket Reconnection
# -----------------------------------------------------------------------------
# RECONNECT_INITIAL_BACKOFF_MS=1000
# RECONNECT_MAX_BACKOFF_MS=60000
# RECONNECT_MAX_DURATION_SECS=300
